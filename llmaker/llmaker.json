{
  "project": "omricode",
  "name": "OmriCode Local Stack",
  "description": "Local LLM infrastructure for OmriCode AI IDE",
  "version": "0.1.0",
  "services": {
    "ollama": {
      "image": "ollama/ollama:latest",
      "port": 11434,
      "health_check": "/api/tags"
    },
    "qdrant": {
      "image": "qdrant/qdrant:latest",
      "port": 6333,
      "health_check": "/"
    },
    "langfuse": {
      "image": "ghcr.io/langfuse/langfuse:latest",
      "port": 3000,
      "health_check": "/api/health"
    }
  },
  "models": [
    {
      "name": "nous-hermes-gguf",
      "source": "https://huggingface.co/NousResearch/Nous-Hermes-2-Mixtral-8x7B-DPO-GGUF",
      "filename": "Nous-Hermes-2-Mixtral-8x7B-DPO.Q4_K_M.gguf",
      "description": "Default unrestricted model with strong function calling",
      "ram": "32GB",
      "recommended": true
    }
  ],
  "defaults": {
    "provider": "local",
    "endpoint": "http://localhost:11434/v1",
    "model": "nous-hermes-gguf",
    "maxTokens": 4096,
    "temperature": 0.7
  }
}
